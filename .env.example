# CJ Licence — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ─── Backend API ──────────────────────────────────────────────────────────────
PORT=3000

# Admin secret — used to authenticate /generate, /list, /revoke endpoints.
# Change this to a long random string!
ADMIN_SECRET=change_me_to_a_long_random_string_here

# ─── CORS (optional) ─────────────────────────────────────────────────────────
# Set to your website domain if you have a web UI, or * to allow all origins.
ALLOWED_ORIGIN=*
